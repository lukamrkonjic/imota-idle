static func make_palette(tier: Color, dimmed: bool = false) -> Dictionary:
	var a := 0.25 if dimmed else 1.0
	return {
		"#": Color(tier.r, tier.g, tier.b, a),
		"*": Color(tier.lightened(0.45).r, tier.lightened(0.45).g, tier.lightened(0.45).b, a),
		"+": Color(0.45, 0.31, 0.18, a),
		"@": Color(0.32, 0.22, 0.12, a),
		"o": Color(0.22, 0.22, 0.26, a),
		"=": Color(0.48, 0.50, 0.54, a),
		"~": Color(0.18, 0.42, 0.72, a),
	}


## Legacy 12-row maps are centered inside the 16-row grid.
static func get_map(kind: String) -> Array:
	var raw: Array = MAPS.get(kind, MAPS["tree"])
	var out: PackedStringArray = []
	var pad_top := maxi(0, (GRID - raw.size()) / 2)
	for y: int in GRID:
		if y < pad_top or y >= pad_top + raw.size():
			out.append(".".repeat(GRID))
			continue
		var row: String = str(raw[y - pad_top])
		if row.length() < GRID:
			var left := (GRID - row.length()) / 2
			row = ".".repeat(left) + row + ".".repeat(GRID - row.length() - left)
		out.append(row.substr(0, GRID))
	return out


func _ready() -> void:
	custom_minimum_size = Vector2(GRID * PX, GRID * PX)


func _process(delta: float) -> void:
	if animate:
		_t += delta
		queue_redraw()


func _draw() -> void:
	var map: Array = get_map(kind)
	var palette := make_palette(tier_color)
	var origin := (size - Vector2(GRID * PX, GRID * PX)) / 2.0
	if animate:
		if shake:
			origin += Vector2(sin(_t * 40.0) * 2.0, 0.0)
		else:
			origin += Vector2(0.0, sin(_t * 5.0) * 3.0)
	for y: int in GRID:
		var row: String = map[y]
		for x: int in mini(GRID, row.length()):
			var ch := row[x]
			if palette.has(ch):
				draw_rect(Rect2(origin + Vector2(x * PX, y * PX), Vector2(PX, PX)), palette[ch])
