## Procedural chunky-pixel icon for skilling nodes, enemies, and recipes.
## No sprite pipeline: each kind is a 16x16 ASCII map drawn in _draw().
## Pulses (gather/craft) or shakes (combat) while the sim is active.

const GRID := 16
const PX := 4.0  # matches PixelPalette.PX — one art pixel everywhere

var kind := "tree":
	set(v):
		kind = v
		queue_redraw()
var tier_color := Color(0.36, 0.62, 0.26):
	set(v):
		tier_color = v
		queue_redraw()
var animate := false:
	set(v):
		animate = v
		_t = 0.0
		queue_redraw()
var shake := false

var _t := 0.0

