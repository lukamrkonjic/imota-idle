; Engine configuration file.
; Imota — OSRS-inspired semi-idle incremental RPG.
; Data and formulas recreated from the Bloobs Adventure Idle export.

config_version=5

[application]

config/name="Imota"
run/main_scene="res://scenes/world.tscn"
config/features=PackedStringArray("4.6")
boot_splash/show_image=false
boot_splash/bg_color=Color(0.133333, 0.133333, 0.156863, 1)

[autoload]

EventBus="*res://autoload/event_bus.gd"
DataRegistry="*res://autoload/data_registry.gd"
GameState="*res://autoload/game_state.gd"
SkillRegistry="*res://autoload/skill_registry.gd"
TickSim="*res://autoload/tick_sim.gd"
CombatSim="*res://autoload/combat_sim.gd"
RecipeSim="*res://autoload/recipe_sim.gd"
FarmingSim="*res://autoload/farming_sim.gd"
PrayerSim="*res://autoload/prayer_sim.gd"
WorldGen="*res://autoload/world_gen.gd"
SaveManager="*res://autoload/save_manager.gd"
GameSettings="*res://autoload/game_settings.gd"

[debug]

; Donated procedural-decor scripts use Variant-inferred locals; don't fail the
; build on those style warnings (temporary — for the decor showcase).
gdscript/warnings/treat_warnings_as_errors=false
gdscript/warnings/inference_on_variant=1
gdscript/warnings/untyped_declaration=0

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="disabled"

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.133333, 0.133333, 0.156863, 1)
anti_aliasing/quality/msaa_3d=2
